# ===== Gmail SMTP 설정 템플릿 =====
# 이 파일을 복사해 .env 로 만들고 실제 값을 채우세요. (.env 는 절대 공유/커밋 금지)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# 발신 Gmail 주소 (예: abc@gmail.com)
SMTP_USER=your_gmail@gmail.com

# Google 앱 비밀번호 16자리 (공백 없이 붙여써도 되고 공백 포함도 됨)
# 발급: 2단계 인증 켠 뒤 https://myaccount.google.com/apppasswords
SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx

# 메일에 표시될 발신자 이름
SENDER_NAME=회의록 자동화
